{
  "manifest_version": 3,
  "name": "QC Auto Poster",
  "version": "1.0.0",
  "description": "Quantum Connect AI Facebook Marketplace Automation",
  "permissions": ["activeTab", "scripting"],
  "host_permissions": ["https://www.facebook.com/*"],
  "content_scripts": [
    {
      "matches": ["https://www.facebook.com/*"],
      "js": ["dist/content.js"],
      "run_at": "document_idle"
    }
  ],
  "background": {
    "service_worker": "dist/background.js"
  }
}
